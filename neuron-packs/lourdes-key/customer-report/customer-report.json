            "user_code": "orders = payload.body if isinstance(payload.body, list) else (payload.body.get('orders') or payload.body.get('data') or [])\n\nsummary = []\nfor order in orders:\n    summary.append({\n        'order_id': order.get('id'),\n        'status': order.get('status'),\n        'total': order.get('total'),\n        'customer_ref': order.get('customer_ref'),\n    })\n\nresult = {\n    'report': summary,\n    'total_orders': len(summary),\n    'statuses': list({o['status'] for o in summary if o.get('status')}),\n}",
